RewriteEngine on

# Enforce one canonical HTTPS hostname for stronger SEO canonicalization.
RewriteCond %{HTTP_HOST} !^nephrosite\.polascin\.net$ [NC,OR]
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://nephrosite.polascin.net%{REQUEST_URI} [L,R=301]

SetEnvIf Request_URI "^/blocks/" noindex_path=1
SetEnvIf Request_URI "^/segments/" noindex_path=1
SetEnvIf Request_URI "^/ipvrm\.files/" noindex_path=1

<IfModule mod_headers.c>
	Header set X-Robots-Tag "noindex, nofollow, noarchive" env=noindex_path
</IfModule>
